# Public (browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: public site URL for QR codes / booking links (default https://www.mydoccy.com). Use http://localhost:3000 for local testing.
# NEXT_PUBLIC_SITE_URL=

# Server-only: bypasses RLS — required for POST /api/appointments, success + .ics routes, and /internal/directory
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for /internal gate; cookie is set when password matches
INTERNAL_DIRECTORY_SECRET=

# Resend (booking emails). Domain mydoccy.com must be verified in Resend.
RESEND_API_KEY=
# Optional: override From (default: DocCy <no-reply@mydoccy.com>). Use for dev e.g. Resend onboarding sender.
# RESEND_FROM=DocCy <onboarding@resend.dev>
