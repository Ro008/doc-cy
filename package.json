{
  "name": "doccy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "free:3000": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./free-port.ps1\" -Port 3000",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:register:prod": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_LIVE_REGISTRATION='1'; $env:PLAYWRIGHT_BASE_URL='https://mydoccy.com'; playwright test tests/prod/prod_registration_smoke.spec.ts --project='Desktop Large (Chromium)' --reporter=line\"",
    "test:prod:smoke:local": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_ENV_FILE='.env.local'; $env:PLAYWRIGHT_LIVE_REGISTRATION='1'; $env:PLAYWRIGHT_BASE_URL='https://www.mydoccy.com'; playwright test tests/prod/prod_appointment_booking_flow.spec.ts tests/prod/prod_registration_smoke.spec.ts tests/prod/prod_site_availability.spec.ts tests/prod/prod_doctor_password_login_smoke.spec.ts tests/prod/prod_agenda_qr_with_session.spec.ts --project='Desktop Large (Chromium)' --workers=1 --reporter=line\"",
    "test:prod:registration:video:local": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_ENV_FILE='.env.local'; $env:PLAYWRIGHT_LIVE_REGISTRATION='1'; $env:PLAYWRIGHT_BASE_URL='https://www.mydoccy.com'; playwright test tests/prod/prod_registration_smoke.spec.ts --config=playwright.pwa-video.config.ts --project='Desktop Large (Chromium)' --workers=1 --reporter=line --output='tmp/prod-registration-video'\"",
    "test:e2e:i18n-smoke": "playwright test tests/landing_i18n.spec.ts tests/language_switcher.spec.ts",
    "test:e2e:safe": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_SAFE_NO_BOOKING='1'; playwright test\"",
    "test:e2e:ui": "playwright test --ui",
    "test:integration:testing:service-menu": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_ENV_FILE='.env.testing.local'; $env:PLAYWRIGHT_BASE_URL='http://localhost:3100'; $env:PLAYWRIGHT_WEB_SERVER_COMMAND='node scripts/dev-with-env.mjs .env.testing.local 3100'; $env:INTEGRATION_SAFE_ENV='1'; playwright test tests/integration/service_menu_public_profile.integration.spec.ts --project='Desktop Large (Chromium)' --reporter=line\"",
    "test:integration:testing:settings-address-notice": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_ENV_FILE='.env.testing.local'; $env:PLAYWRIGHT_BASE_URL='http://localhost:3100'; $env:PLAYWRIGHT_WEB_SERVER_COMMAND='node scripts/dev-with-env.mjs .env.testing.local 3100'; $env:INTEGRATION_SAFE_ENV='1'; playwright test tests/integration/settings_clinic_address_notice.integration.spec.ts --project='Desktop Large (Chromium)' --reporter=line\"",
    "test:integration:testing:settings-address-notice:video": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_ENV_FILE='.env.testing.local'; $env:PLAYWRIGHT_BASE_URL='http://localhost:3100'; $env:PLAYWRIGHT_WEB_SERVER_COMMAND='node scripts/dev-with-env.mjs .env.testing.local 3100'; $env:INTEGRATION_SAFE_ENV='1'; playwright test tests/integration/settings_clinic_address_notice.integration.spec.ts --config=playwright.pwa-video.config.ts --project='Desktop Large (Chromium)' --reporter=line --output='tmp/settings-address-notice-video'\"",
    "test:integration:testing:service-menu-ui:video": "powershell -NoProfile -Command \"$env:PLAYWRIGHT_ENV_FILE='.env.testing.local'; $env:PLAYWRIGHT_BASE_URL='http://localhost:3100'; $env:PLAYWRIGHT_WEB_SERVER_COMMAND='node scripts/dev-with-env.mjs .env.testing.local 3100'; $env:INTEGRATION_SAFE_ENV='1'; playwright test tests/integration/service_menu_settings_ui.integration.spec.ts --config=playwright.pwa-video.config.ts --project='Desktop Large (Chromium)' --reporter=line --output='tmp/service-menu-ui-video'\"",
    "test:e2e:pwa:video:tmp": "node -e \"require('fs').rmSync('tmp/pwa-video',{recursive:true,force:true})\" && npx playwright test tests/pwa_install_banner.spec.ts --config=playwright.pwa-video.config.ts --project=\"Mobile Chrome (Pixel 5)\" --project=\"Mobile Safari (iPhone 12)\" --reporter=line --output=\"tmp/pwa-video\"",
    "seed:languages": "node scripts/seed-doctor-languages.mjs",
    "db:status": "node scripts/supabase-safe.mjs status",
    "db:testing:link": "node scripts/supabase-safe.mjs link-testing",
    "db:testing:push": "node scripts/supabase-safe.mjs push-testing",
    "db:prod:link": "node scripts/supabase-safe.mjs link-prod",
    "db:prod:push": "node scripts/supabase-safe.mjs push-prod"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.8.0",
    "@supabase/supabase-js": "^2.39.0",
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.0",
    "next-intl": "^4.8.3",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18",
    "react-easy-crop": "^5.5.7",
    "react-international-phone": "^4.2.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5"
  }
}
